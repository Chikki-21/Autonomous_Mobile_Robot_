<?xml version = "1.0"?>
<launch>
    <let name = "urdf_path" value ="$(find-pkg-share scout_bot_description)/urdf/compound.urdf.xacro"/>

    <let name = "gz_config_path" value="$(find-pkg-share scout_bot_bringup)/config/gz_bridge.yaml"/>

    <let name = "nav2_params" value="$(find-pkg-share scout_bot_bringup)/config/nav2_param.yaml"/>

    <let name = "rviz_config" value="$(find-pkg-share scout_bot_bringup)/world/Rviz_config.rviz"/>

    <let name = "ware_map" value="$(find-pkg-share scout_bot_bringup)/maps/aws_map.yaml"/>

    <node pkg = "robot_state_publisher" exec="robot_state_publisher">
        <param name ="robot_description" value="$(command 'xacro $(var urdf_path)')"/>
        <param name="publish_frequency" value="100.0"/>
        <param name="use_sim_time" value="True"/>
    </node>

    <!-- <node pkg="joint_state_publisher" exec="joint_state_publisher">
        <param name="use_sim_time" value="True"/>
    </node> -->

    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
        <arg name="gz_args" value="$(find-pkg-share scout_bot_bringup)/world/aws_warehouse.sdf -r" />
        <!-- <arg name="gz_args" value="empty.sdf -r"/> -->
    </include>

    <node pkg ="ros_gz_sim" exec="create" args="-topic robot_description">
       <param name="use_sim_time" value="True"/>
    </node>
    

    <node pkg="ros_gz_bridge" exec="parameter_bridge">
        <param name="config_file" value="$(var gz_config_path)"/>
        <param name="use_sim_time" value="True"/>
    </node>

    <node pkg="scout_bot_bringup" exec="odom_tf_publisher.py" name="odom_tf_publisher" output="screen">
        <param name="use_sim_time" value="True"/>
        <param name="odom_topic" value="/odom"/>
        <param name="odom_frame" value="odom"/>
        <param name="base_frame" value="base_footprint"/>
    </node>
    
    <include file="$(find-pkg-share nav2_bringup)/launch/bringup_launch.py">
        <arg name="map" value="$(var ware_map)"/>
        <arg name="params_file" value="$(var nav2_params)"/>
        <arg name="use_sim_time" value="True"/>
        <arg name="autostart" value="True"/>
        <arg name="use_composition" value="False"/>
    </include>

    <node pkg="rviz2" exec="rviz2" output="screen" args = "-d $(var rviz_config)">
        <param name="use_sim_time" value="True"/>
    </node>
   

</launch>
